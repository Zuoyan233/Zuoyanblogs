---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";
import { contactMethods } from "@/config";

export interface Props {
	qrCodes?: string[]; // 改为接收数组
}

const { qrCodes } = Astro.props;

// 如果有传入 qrCodes 则使用，否则使用配置中的所有
const methodsToShow = qrCodes
	? contactMethods.filter((method) => qrCodes.includes(method.qrCode))
	: contactMethods.filter((method) => method.qrCode);
---

<dialog
  id="contact-dialog"
  class="dialog fixed inset-0 m-auto border border-[var(--line-divider)] rounded-[var(--radius-large)] bg-[var(--float-panel-bg)] p-0 w-[90%] max-w-[480px] shadow-lg overflow-hidden transition-all duration-250 ease-[cubic-bezier(0.2,0,0,1)] opacity-0 scale-95 translate-y-2.5 dialog-show:opacity-100 dialog-show:scale-100 dialog-show:translate-y-0"
>
  <div class="absolute inset-0 bg-[image:var(--dialog-bg-img)] bg-auto bg-right-bottom bg-no-repeat opacity-18 z-0 pointer-events-none"></div>

  <div class="relative z-10 p-8 pb-7 flex flex-col gap-5">
    <!-- 标题 -->
    <div class="flex items-center justify-center gap-2.5 text-[var(--primary)]">
      <Icon name="material-symbols:qr-code-scanner" class="text-3xl"></Icon>
      <h3 class="m-0 text-[1.35rem] font-semibold text-[var(--btn-plain)]">{i18n(I18nKey.addFriends)}</h3>
    </div>

    <!-- 二维码容器 -->
    <div class="flex flex-col gap-5">
      <!-- 标签切换按钮组 -->
      {methodsToShow.length > 0 && (
        <div class="flex justify-center gap-3">
          {methodsToShow.map((method, idx) => (
            <button
              data-tab-id={method.method}
              class="tab-btn {idx === 0 ? 'active bg-[var(--btn-regular-bg)] text-[var(--btn-content)]' : 'bg-transparent border-2 border-[var(--primary)] text-[var(--primary)]'} flex-1 max-w-[120px] border-none rounded-lg py-2 px-4 text-sm font-medium cursor-pointer transition-all duration-200 hover:bg-[var(--btn-plain-bg-hover)]"
            >
              <span class="flex items-center justify-center gap-1.5">
                <Icon name={method.icon} class="text-lg"></Icon>
                {i18n(I18nKey[`contactMethod${idx + 1}` as keyof typeof I18nKey])}
              </span>
            </button>
          ))}
        </div>
      )}

      <!-- 二维码展示区 -->
      <div class="qr-display relative">
        {methodsToShow.map((method, idx) => (
          <div 
            data-panel-id={method.method} 
            class="qr-panel {idx === 0 ? 'flex' : 'hidden'} flex-col items-center gap-4"
          >
            <div class="bg-white p-3 rounded-xl shadow-md">
              <img 
                src={method.qrCode} 
                class="w-56 h-56 object-contain" 
                loading="lazy" 
                alt={`${method.method} QR Code`} 
              />
            </div>
            <p class="m-0 text-sm text-[var(--content-meta)] flex items-center gap-1.5">
              <Icon name="material-symbols:camera" class="text-lg"></Icon>
              {i18n(I18nKey[`scanContact${idx + 1}` as keyof typeof I18nKey])}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- 关闭按钮 -->
    <div class="flex justify-center mt-2">
      <button
        id="dialog-close-btn"
        class="border-none rounded-[8px] py-2.5 px-7 text-[0.95rem] font-semibold cursor-pointer transition-all duration-200 ease-[cubic-bezier(0.4,0,0.2,1)] active:scale-95 bg-transparent border-2 border-[var(--primary)] text-[var(--primary)] hover:bg-[var(--btn-plain-bg-hover)]"
      >
        {i18n(I18nKey.cancelText)}
      </button>
    </div>
  </div>
</dialog>

<style>
  .dialog.dialog-show {
    @apply opacity-100 scale-100 translate-y-0;
  }
  
  .dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(5px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  
  .dialog.dialog-show::backdrop {
    opacity: 1;
  }

  .qr-panel {
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  class ContactDialogManager {
    private dialog: HTMLDialogElement | null = null;
    private cleanupFns: (() => void)[] = [];

    init() {
      this.dialog = document.getElementById("contact-dialog") as HTMLDialogElement;
      if (!this.dialog) {
        console.warn("Contact dialog not found");
        return;
      }

      this.bindEvents();
      this.setupGlobalApi();
    }

    private bindEvents() {
      const closeBtn = document.getElementById("dialog-close-btn");
      const tabBtns = this.dialog?.querySelectorAll("[data-tab-id]");
      const panels = this.dialog?.querySelectorAll("[data-panel-id]");

      // 关闭对话框
      const closeDialog = () => {
        this.dialog?.classList.remove("dialog-show");
        setTimeout(() => {
          if (this.dialog?.open) {
            this.dialog.close();
          }
        }, 250);
      };

      // 关闭按钮事件
      const handleCloseClick = () => closeDialog();
      closeBtn?.addEventListener("click", handleCloseClick);
      this.cleanupFns.push(() => closeBtn?.removeEventListener("click", handleCloseClick));

      // 点击背景关闭
      const handleBackdropClick = (e: Event) => {
        if (e.target === this.dialog) closeDialog();
      };
      this.dialog?.addEventListener("click", handleBackdropClick);
      this.cleanupFns.push(() => this.dialog?.removeEventListener("click", handleBackdropClick));

      // 标签切换逻辑
      const switchTab = (targetBtn: Element) => {
        const tabId = targetBtn.getAttribute("data-tab-id");
        
        // 更新按钮样式
        tabBtns?.forEach(btn => {
          btn.classList.remove("active", "bg-[var(--btn-regular-bg)]", "text-[var(--btn-content)]");
          btn.classList.add("bg-transparent", "border-2", "border-[var(--primary)]", "text-[var(--primary)]");
        });
        targetBtn.classList.remove("bg-transparent", "border-2", "border-[var(--primary)]", "text-[var(--primary)]");
        targetBtn.classList.add("active", "bg-[var(--btn-regular-bg)]", "text-[var(--btn-content)]");

        // 更新面板显示
        panels?.forEach(panel => {
          const panelId = panel.getAttribute("data-panel-id");
          if (panelId === tabId) {
            panel.classList.remove("hidden");
            panel.classList.add("flex");
          } else {
            panel.classList.add("hidden");
            panel.classList.remove("flex");
          }
        });
      };

      // 绑定标签按钮事件
      tabBtns?.forEach(btn => {
        const handler = () => switchTab(btn);
        btn.addEventListener("click", handler);
        this.cleanupFns.push(() => btn.removeEventListener("click", handler));
      });
    }

    private setupGlobalApi() {
      if (!(window as any).showContactDialog) {
        (window as any).showContactDialog = () => {
          if (!this.dialog) return;
          
          // 重置到第一个标签
          const firstTab = this.dialog.querySelector("[data-tab-id]");
          if (firstTab) {
            const tabId = firstTab.getAttribute("data-tab-id");
            const panels = this.dialog.querySelectorAll("[data-panel-id]");
            const tabBtns = this.dialog.querySelectorAll("[data-tab-id]");
            
            // 重置按钮样式
            tabBtns.forEach(btn => {
              btn.classList.remove("active", "bg-[var(--btn-regular-bg)]", "text-[var(--btn-content)]");
              btn.classList.add("bg-transparent", "border-2", "border-[var(--primary)]", "text-[var(--primary)]");
            });
            firstTab.classList.remove("bg-transparent", "border-2", "border-[var(--primary)]", "text-[var(--primary)]");
            firstTab.classList.add("active", "bg-[var(--btn-regular-bg)]", "text-[var(--btn-content)]");

            // 重置面板显示
            panels.forEach(panel => {
              const panelId = panel.getAttribute("data-panel-id");
              if (panelId === tabId) {
                panel.classList.remove("hidden");
                panel.classList.add("flex");
              } else {
                panel.classList.add("hidden");
                panel.classList.remove("flex");
              }
            });
          }
          
          this.dialog.showModal();
          setTimeout(() => this.dialog?.classList.add("dialog-show"), 10);
        };
      }
    }

    destroy() {
      this.cleanupFns.forEach(fn => fn());
      this.cleanupFns = [];
      this.dialog = null;
    }
  }

  const manager = new ContactDialogManager();

  // Astro 生命周期管理
  document.addEventListener('astro:page-load', () => {
    manager.init();
  });

  document.addEventListener('astro:before-swap', () => {
    manager.destroy();
  });

  // 初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => manager.init());
  } else {
    manager.init();
  }
</script>