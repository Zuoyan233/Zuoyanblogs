---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "../../utils/content-utils";
import { allTranslations } from "../../utils/i18n-dom-updater";
import { translateToLangMap } from "../../utils/language-utils";
import WidgetLayout from "./WidgetLayout.astro";

const periodKeys = [
	I18nKey.siteStatsTimePeriodMorning,
	I18nKey.siteStatsTimePeriodNoon,
	I18nKey.siteStatsTimePeriodAfternoon,
	I18nKey.siteStatsTimePeriodEvening,
	I18nKey.siteStatsTimePeriodNight,
] as const;
const amPmKeys = [I18nKey.siteStatsAm, I18nKey.siteStatsPm] as const;

// 从 allTranslations 构建时间段/日期格式/AM-PM 映射表
const periodTranslations: Record<string, string[]> = {};
const amPmTranslations: Record<string, string[]> = {};
const dateFormats: Record<string, string> = {};

for (const [lang, tr] of Object.entries(allTranslations)) {
	periodTranslations[lang] = periodKeys.map((k) => tr[k] || "");
	amPmTranslations[lang] = amPmKeys.map((k) => tr[k] || "");
	dateFormats[lang] = tr[I18nKey.siteStatsDateFormat] || "{month}/{day}/{year}";
}

// 构建后缀翻译映射表（用于客户端语言切换时更新单位文本）
const suffixTranslations: Record<string, Record<string, string>> = {};
for (const [lang, tr] of Object.entries(allTranslations)) {
	suffixTranslations[lang] = {
		"running-days": tr[I18nKey.siteStatsDays] || "",
		"last-update": tr[I18nKey.siteStatsDaysAgo] || "",
	};
}

const periodTranslationsJSON = JSON.stringify(periodTranslations);
const amPmTranslationsJSON = JSON.stringify(amPmTranslations);
const dateFormatsJSON = JSON.stringify(dateFormats);
const suffixTranslationsJSON = JSON.stringify(suffixTranslations);
const translateToI18nMapJSON = JSON.stringify(translateToLangMap);

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// 从配置中获取站点开始日期和动态更新、时间段显示
const siteStartDate = siteConfig.siteStats.siteStartDate || "1970-01-01";
const enableDynamic = siteConfig.siteStats?.dynamicEnable ?? true;
const enableShowPeriod = siteConfig.siteStats?.dynamicEnable ?? true;
const enable12HourClock = siteConfig.siteStats?.enable12HourClock ?? false;

// 获取所有文章
const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();

// 计算总字数
let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		let text = post.body;

		// 移除代码块
		text = text.replace(/```[\s\S]*?```/g, "");
		// 移除 ` 包裹的行内代码
		text = text.replace(/`[^`]+`/g, "");

		// 使用与 remark-content.mjs 完全一致的 CJK 正则
		const cjkPattern =
			/[\u4e00-\u9fa5\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af\u3000-\u303f\uff00-\uffef]/g;

		const cjkMatches = text.match(cjkPattern);
		const cjkCount = cjkMatches ? cjkMatches.length : 0;

		// 计算非 CJK 单词数
		const nonCjkText = text.replace(cjkPattern, " ");

		// 按空白字符分割，计算单词数量
		const nonCjkWords = nonCjkText
			.split(/\s+/)
			.filter((word) => word.trim().length > 0);

		totalWords += cjkCount + nonCjkWords.length;
	}
}

// 格式化数字（添加千位分隔符）
function formatNumber(num: number): string {
	return num.toLocaleString();
}

// 获取最新文章日期（忽略置顶状态，只按发布日期排序）
const latestPost = posts.reduce((latest, post) => {
	if (!latest) return post;
	return post.data.published > latest.data.published ? post : latest;
}, posts[0]);

const lastPostDate = latestPost
	? latestPost.data.published.toISOString()
	: null;

// 计算基准日期（使用UTC中午避免时区问题）
function getUTCDate(dateStr: string): Date {
	// 使用 UTC 中午12点避免时区偏移问题
	return new Date(`${dateStr}T12:00:00Z`);
}

// 计算运行天数（基准值，客户端会重新计算）
const startBaseDate = getUTCDate(siteStartDate);
const nowBase = new Date();
const baseRunningDays = Math.max(
	1,
	Math.floor(
		(nowBase.getTime() - startBaseDate.getTime()) / (1000 * 60 * 60 * 24),
	) + 1,
);

// 计算最后更新天数（基准值）
let baseDaysSinceLastUpdate = 0;
if (lastPostDate) {
	const lastPostBase = new Date(lastPostDate);
	baseDaysSinceLastUpdate = Math.max(
		0,
		Math.floor(
			(nowBase.getTime() - lastPostBase.getTime()) / (1000 * 60 * 60 * 24),
		),
	);
}

// 获取日期格式
const dateFormatStr =
	i18n(I18nKey.siteStatsDateFormat) || "{year}年{month}月{day}日";

// 计算当前日期（基准值，客户端会重新计算）
const baseCurrentDate = dateFormatStr
	.replace("{year}", String(nowBase.getFullYear()))
	.replace("{month}", String(nowBase.getMonth() + 1))
	.replace("{day}", String(nowBase.getDate()));

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
	},
	{
		icon: "material-symbols:folder-outline",
		label: i18n(I18nKey.siteStatsCategoryCount),
		value: categories.length,
	},
	{
		icon: "material-symbols:label-outline",
		label: i18n(I18nKey.siteStatsTagCount),
		value: tags.length,
	},
	{
		icon: "material-symbols:text-ad-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalWords),
		value: totalWords,
		formatted: true,
	},
	{
		icon: "material-symbols:calendar-clock-outline",
		label: i18n(I18nKey.siteStatsRunningDays),
		value: baseRunningDays,
		suffix: i18n(I18nKey.siteStatsDays).replace("{days}", ""),
		dynamic: enableDynamic, // 是否动态更新
		updateInterval: "daily", // 每天更新
		id: "running-days",
	},
	{
		icon: "material-symbols:ecg-heart-outline",
		label: i18n(I18nKey.siteStatsLastUpdate),
		value: baseDaysSinceLastUpdate,
		suffix: i18n(I18nKey.siteStatsDaysAgo).replace("{days}", ""),
		dynamic: enableDynamic, // 是否动态更新
		updateInterval: "daily", // 每天更新
		id: "last-update",
	},
	{
		icon: "material-symbols:calendar-month-outline",
		label: i18n(I18nKey.siteStatsCurrentDate),
		value: baseCurrentDate,
		dynamic: enableDynamic, // 是否动态更新
		updateInterval: "daily", // 每天更新
		id: "current-date",
		useFormattedDate: true,
	},
	{
		icon: "material-symbols:schedule-outline",
		label: i18n(I18nKey.siteStatsCurrentTime),
		dynamic: enableDynamic, // 是否动态更新
		updateInterval: "second", // 每秒更新
		id: "current-time",
		showPeriod: enableShowPeriod, // 是否显示时间段
		use12Hour: enable12HourClock, // 是否使用12小时制
	},
];
---

<WidgetLayout
	name={i18n(I18nKey.siteStats)}
	id="site-stats"
	class={className}
	style={style}
>
	<div class="ignore flex flex-col gap-1">
		{
			stats.map((stat) => {
				if (stat.dynamic === false && stat.value === undefined) return null;
				
				return (
					<div class="flex items-center justify-between px-2 py-2">
						<div class="flex items-center gap-2.5 flex-1 min-w-0">
							<div class="text-[var(--primary)] text-xl shrink-0">
								<Icon name={stat.icon} />
							</div>
							<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
								{stat.label}
							</span>
						</div>
						<div class="flex items-center ml-3 shrink-0">
							{stat.showPeriod && !stat.use12Hour ? (
								<div class="flex items-center gap-1">
									<span
										class="text-base font-bold text-neutral-900 dark:text-neutral-100"
										data-stat-id={stat.id}
										data-update-interval={stat.updateInterval}
									>
										{ (stat as any).formatted ? formatNumber((stat as any).value) : (stat as any).value }
									</span>
									<span
										class="text-sm text-neutral-500 dark:text-neutral-400"
										data-stat-id="time-period"
									>
									</span>
								</div>
							) : stat.showPeriod && stat.use12Hour ? (
								<div class="flex items-center gap-1">
									<span
										class="text-base font-bold text-neutral-900 dark:text-neutral-100"
										data-stat-id={stat.id}
										data-update-interval={stat.updateInterval}
										data-use-12-hour="true"
									>
										{ (stat as any).formatted ? formatNumber((stat as any).value) : (stat as any).value }
									</span>
									<span
										class="text-sm text-neutral-500 dark:text-neutral-400"
										data-stat-id="time-ampm"
									>
									</span>
								</div>
							) : stat.useFormattedDate ? (
								<span
									class="inline-flex items-baseline gap-0.5 text-base font-bold text-neutral-900 dark:text-neutral-100"
									data-stat-id={stat.id}
									data-formatted-date="true"
								>
								</span>
							) : (
								<>
									<span
										class="text-base font-bold text-neutral-900 dark:text-neutral-100"
										data-stat-id={stat.dynamic ? stat.id : undefined}
										data-update-interval={stat.updateInterval}
									>
										{ (stat as any).formatted ? formatNumber((stat as any).value) : (stat as any).value }
									</span>
									{stat.suffix && (
										<span class="text-sm text-neutral-500 dark:text-neutral-400 ml-1" data-stat-suffix={stat.id}>
											{stat.suffix}
										</span>
									)}
								</>
							)}
						</div>
					</div>
				);
			})
		}
	</div>
</WidgetLayout>



<script is:inline define:vars={{ 
	siteStartDate, 
	lastPostDate,
	periodTranslationsJSON,
	amPmTranslationsJSON,
	dateFormatsJSON,
	suffixTranslationsJSON,
	translateToI18nMapJSON,
	defaultLang: siteConfig.lang,
}}>
	// 解析服务端生成的翻译映射表
	const periodTranslations = JSON.parse(periodTranslationsJSON);
	const amPmTranslations = JSON.parse(amPmTranslationsJSON);
	const dateFormats = JSON.parse(dateFormatsJSON);
	const suffixTranslations = JSON.parse(suffixTranslationsJSON);
	const translateToLangMap = JSON.parse(translateToI18nMapJSON);
	
	// 获取当前翻译服务的 i18n 语言代码，无翻译服务时回退到页面默认语言
	function getCurrentI18nLang() {
		const translateTo =
			window.translationManager?.getTargetLanguage() || window.translate?.to;
		if (translateTo) {
			return translateToLangMap[translateTo] || defaultLang;
		}
		return defaultLang;
	}
	
	// 获取当前语言的日期格式
	function getCurrentDateFormat() {
		const lang = getCurrentI18nLang();
		return dateFormats[lang] || dateFormats.en || "{month}/{day}/{year}";
	}
	
	// 获取时间段
	function getTimePeriod(hours, periodVals) {
		const vals = periodVals || Object.values(periodTranslations)[0];
		if (hours >= 5 && hours < 11) {
			return vals[0];
		} else if (hours >= 11 && hours < 13) {
			return vals[1];
		} else if (hours >= 13 && hours < 18) {
			return vals[2];
		} else if (hours >= 18 && hours < 20) {
			return vals[3];
		} else {
			return vals[4];
		}
	}

	function getUTCDate(dateStr) {
		if (typeof dateStr === 'string') {
			return new Date(`${dateStr}T12:00:00Z`);
		}
		return new Date(dateStr);
	}

	function formatTime24(date) {
		const hours = String(date.getHours()).padStart(2, '0');
		const minutes = String(date.getMinutes()).padStart(2, '0');
		const seconds = String(date.getSeconds()).padStart(2, '0');
		return `${hours}:${minutes}:${seconds}`;
	}

	function formatTime12(date) {
		let hours = date.getHours();
		const minutes = String(date.getMinutes()).padStart(2, '0');
		const seconds = String(date.getSeconds()).padStart(2, '0');
		hours = hours % 12;
		hours = hours ? hours : 12; // 0点显示为12
		return `${hours}:${minutes}:${seconds}`;
	}

	function getTimeAmPm(date) {
		const lang = getCurrentI18nLang();
		const vals = amPmTranslations[lang] || amPmTranslations.en;
		return date.getHours() >= 12 ? vals[1] : vals[0];
	}

	// 简化的日期格式化函数
	function updateFormattedDate(element, today) {
		const year = today.getFullYear();
		const month = today.getMonth() + 1;
		const day = today.getDate();
		
		// 根据当前翻译语言获取日期格式
		const format = getCurrentDateFormat();
		
		// 使用正则表达式分割格式字符串
		const parts = format.split(/(\{year\}|\{month\}|\{day\})/g);
		
		let html = '';
		
		parts.forEach(part => {
			if (part === '{year}') {
				html += `<span class="text-base leading-6 font-bold text-neutral-900 dark:text-neutral-100">${year}</span>`;
			} else if (part === '{month}') {
				html += `<span class="text-base leading-6 font-bold text-neutral-900 dark:text-neutral-100">${month}</span>`;
			} else if (part === '{day}') {
				html += `<span class="text-base leading-6 font-bold text-neutral-900 dark:text-neutral-100">${day}</span>`;
			} else if (part) {
				html += `<span class="text-sm leading-5 text-neutral-500 font-normal mx-px dark:text-neutral-400">${part}</span>`;
			}
		});
		
		if (element.innerHTML !== html) {
			element.innerHTML = html;
		}
	}

	// 计算运行天数
	function updateRunningDays(element, today) {
		if (!siteStartDate) return;
		
		const startDate = getUTCDate(siteStartDate);
		const diffTime = today.getTime() - startDate.getTime();
		const diffDays = Math.max(1, Math.floor(diffTime / (1000 * 60 * 60 * 24)) + 1);
		
		if (element.textContent !== String(diffDays)) {
			element.textContent = diffDays;
		}
	}

    // 计算最后更新天数
	function updateLastUpdate(element, today) {
		if (!lastPostDate) return;
		
		const lastPost = new Date(lastPostDate);
		const diffTime = today.getTime() - lastPost.getTime();
		const daysSinceLastUpdate = Math.max(0, Math.floor(diffTime / (1000 * 60 * 60 * 24)));
		
		if (element.textContent !== String(daysSinceLastUpdate)) {
			element.textContent = daysSinceLastUpdate;
		}
	}

    // 计算当前日期
	function updateCurrentDate(element, today) {
		const isFormatted = element.hasAttribute('data-formatted-date');
		
		if (isFormatted) {
			updateFormattedDate(element, today);
		} else {
			// 兼容旧的格式
			const newDate = `${today.getFullYear()}-${today.getMonth() + 1}-${today.getDate()}`;
			if (element.textContent !== newDate) {
				element.textContent = newDate;
			}
		}
	}

	// 计算当前时间
	function updateCurrentTime(element, today) {
		const use12Hour = element.hasAttribute('data-use-12-hour') && element.getAttribute('data-use-12-hour') === 'true';
		const newTime = use12Hour ? formatTime12(today) : formatTime24(today);
		if (element.textContent !== newTime) {
			element.textContent = newTime;
		}

		// 更新AM/PM标识
		if (use12Hour) {
			const ampmElement = document.querySelector('[data-stat-id="time-ampm"]');
			if (ampmElement) {
				const ampm = getTimeAmPm(today);
				if (ampmElement.textContent !== ampm) {
					ampmElement.textContent = ampm;
				}
			}
		}
	}

	// 计算当前时间段
	function updateTimePeriod(today) {
		const timePeriodElement = document.querySelector('[data-stat-id="time-period"]');
		if (timePeriodElement) {
			const hours = today.getHours();
			const lang = getCurrentI18nLang();
			const vals = periodTranslations[lang] || periodTranslations.en;
			const period = getTimePeriod(hours, vals);
			
			if (timePeriodElement.textContent !== period) {
				timePeriodElement.textContent = period;
			}
		}
	}

	// 更新所有动态统计
	function updateDynamicStats() {
		try {
			const today = new Date();
			
			const runningDaysElement = document.querySelector('[data-stat-id="running-days"]');
			const lastUpdateElement = document.querySelector('[data-stat-id="last-update"]');
			const currentDateElement = document.querySelector('[data-stat-id="current-date"]');
			const currentTimeElement = document.querySelector('[data-stat-id="current-time"]');
			
			if (runningDaysElement) updateRunningDays(runningDaysElement, today);
			if (lastUpdateElement) updateLastUpdate(lastUpdateElement, today);
			if (currentDateElement) updateCurrentDate(currentDateElement, today);
			if (currentTimeElement) updateCurrentTime(currentTimeElement, today);
			
			updateTimePeriod(today);
		} catch (error) {
			console.error('Error updating stats:', error);
		}
	}

	let intervalId = null;
	let dailyIntervalId = null;
	let minuteIntervalId = null;

	// 启动定时器
	function startIntervals() {
		if (intervalId) clearInterval(intervalId);
		if (dailyIntervalId) clearInterval(dailyIntervalId);
		if (minuteIntervalId) clearInterval(minuteIntervalId);
		
		intervalId = setInterval(updateDynamicStats, 1000);
		dailyIntervalId = setInterval(updateDynamicStats, 3600000);
		minuteIntervalId = setInterval(updateDynamicStats, 60000);
		
		updateDynamicStats();
	}

	// 停止定时器
	function stopIntervals() {
		if (intervalId) {
			clearInterval(intervalId);
			intervalId = null;
		}
		if (dailyIntervalId) {
			clearInterval(dailyIntervalId);
			dailyIntervalId = null;
		}
		if (minuteIntervalId) {
			clearInterval(minuteIntervalId);
			minuteIntervalId = null;
		}
	}

	// 监听页面可见性变化
	function handleVisibilityChange() {
		if (document.hidden) {
			stopIntervals();
		} else {
			startIntervals();
		}
	}

	if (typeof document !== 'undefined') {
		startIntervals();
		document.addEventListener('visibilitychange', handleVisibilityChange);
		window.addEventListener('beforeunload', () => {
			stopIntervals();
			document.removeEventListener('visibilitychange', handleVisibilityChange);
		});
	}

	// 后缀渲染器：语言切换时更新单位文本，防止落至 translate.js 翻译通道
	function registerSuffixRenderer() {
		if (!window.translationManager) return;
		window.translationManager.onRefresh('site-stats-suffix', () => {
			const lang = getCurrentI18nLang();
			const langSuffixData = suffixTranslations[lang] || suffixTranslations['en'];

			document.querySelectorAll('[data-stat-suffix]').forEach(el => {
				const statId = el.getAttribute('data-stat-suffix');
				if (statId && langSuffixData[statId]) {
					const text = langSuffixData[statId].replace('{days}', '').trim();
					if (el.textContent !== text) {
						el.textContent = text;
						el.classList.add('ignore');
						el.setAttribute('data-i18n-handled', 'true');
					}
				}
			});
		});
	}

	registerSuffixRenderer();
	document.addEventListener('translation-manager:ready', registerSuffixRenderer, { once: true });
</script>
